# Resend API key — https://resend.com/api-keys
# Tanpa ini, tombol "Kirim ke Email" akan menampilkan pesan konfigurasi.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Alamat pengirim. Untuk uji coba cepat gunakan onboarding@resend.dev.
# Untuk produksi, verifikasi domain Anda di Resend lalu pakai mis. reports@domainanda.com
REPORT_FROM_EMAIL=onboarding@resend.dev
